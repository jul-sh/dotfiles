// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "disable_ai": true,
  "git_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "model": "opus[1m]",
      },
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "agent": {
    "always_allow_tool_actions": true,
    "model_parameters": [],
  },
  "ui_font_size": 20,
  "buffer_font_size": 20,
  "buffer_font_family": "Iosevka Charon Mono",
  "ui_font_family": "Iosevka Charon",
  "unnecessary_code_fade": 0.2,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
}
