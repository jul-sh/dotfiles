{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(~/Downloads/**)"
    ]
  },
  "model": "fable",
  "statusLine": {
    "type": "command",
    "command": "/Users/julsh/.claude/statusline-kawaii.sh"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "captain-codex@jul-sh-claude-plugins": true
  },
  "extraKnownMarketplaces": {
    "jul-sh": {
      "source": {
        "source": "github",
        "repo": "jul-sh/claude-plugins"
      }
    }
  },
  "alwaysThinkingEnabled": false,
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "autoApprove": {
    "enabled": true,
    "commands": [
      "*"
    ],
    "filesystem": [
      "*"
    ],
    "riskLevel": "high"
  },
  "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
  "bashToolTimeout": 1500000
}
